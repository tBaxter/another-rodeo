<!DOCTYPE html>
<html lang="en">
{%- set pageTitle %}{% if title %}{{ title|safe }} | {% endif %}{{ meta.siteName }}{% endset -%}
{%- set pageDescription %}{% if description %}{{ description }}{% else %}{{ meta.siteDescription }}{% endif %}{% endset -%}
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content="{{ eleventy.generator }}" />
    <title>{{pageTitle|safe }}</title>
    <meta name="description" content="{{pageDescription}}" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Goudy+Bookletter+1911&family=Lora:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    <link href="{{ '/css/main.css' | url }}" rel="stylesheet" />

    <link rel="icon" href="{{ '/img/horseshoe.svg' | url }}?v=4" />

    <link rel="alternate" type="application/rss+xml" title="RSS Feed for {{ meta.siteName }}" href="/feed/" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@another.rodeo" />
    <meta property="og:title" content="{{pageTitle}}" />
    <meta name="twitter:title" content="{{pageTitle}}" />
    <meta property="og:description" content="{{pageDescription}}" />
    <meta name="twitter:description" content="{{pageDescription}}" />
    {% if thumb %}
      <meta property="og:image" content="https://another.rodeo{{img_path}}{{thumb}}" />
      <meta name="twitter:image" content="https://another.rodeo{{img_path}}{{thumb}}"/>
    {% else %}
      <meta property="og:image" content="https://another.rodeo/img/horseshoe.svg" />
    {% endif %}
  </head>
  <body>
    {% include 'topnav.njk' %}
    <div class="wrapper">
      {%- if thumb %}
        <figure>
          <img src="{{ img_path }}{{ thumb }}" alt="{{ thumb_alt }}">
        </figure>
      {% endif %}
      {{ content | safe }}
      </div>
      <footer>
        <div>
          <p>
            &copy; {% year %} {{ meta.siteName }} 
            • <a href="/about-carter">Carter Baxter</a>
            • <a href="/links">Links</a>
            • <a href="/contact">Contact</a>
          </p>
        </div>
      </footer>
    <!-- goatcounter is an open source, privacy-friendly web analytics platform. https://www.goatcounter.com/ -->
    <script data-goatcounter="https://rodeo.goatcounter.com/count"
        async src="//gc.zgo.at/count.js"></script>
    <!-- Global person JSON-LD- -->
    <script type="application/ld+json">

        {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Carter Baxter",
      "alternateName": "Tim Baxter",
      "url": "https://another.rodeo",
      "knowsAbout": [
        "Digital Transformation and Modernization",
        "Program Delivery Optimization"
        "Portfolio Execution",
        "Technology & Operating Strategy",
        "Operational Excellence",
        "Multi-Disciplinary Leadership",
        "Product Strategy & Portfolio Alignment",
        "AI Strategy & Enterprise Adoption",
        "Web Development",
        "Mobile Development",
        "Python",
        "Government Digital Services",
        "Government Contracting",
        "Business Development",
        "Partner Relationship Management",
        "Regulatory Compliance",
        "Full-Stack Development",
        "Web Applications",
        "Web Project Management",
        "Agile Methodologies and Delivery",
        "Enterprise Platform & Cloud Strategy",
        "Engineering Leadership & Delivery Management",
        "Organizational Design and Change Management",
        "Risk Management",
        "Strategic Leadership",
        "People Management",
        "Team Building",
        "Mentorship",
        "Remote Team Leadership",
        "Executive Advisory & Stakeholder Management",
        "Writing",
        "Content Strategy",
        "User Experience",
        "E-commerce",
        "JavaScript",
        "CSS",
        "HTML",
        "Pants",
        "Dolphin facts",
        "Banter",
        "Bikes",
        "Nerd stuff"
      ],
      "sameAs": [
        "https://www.linkedin.com/in/carter-baxter",
        "https://github.com/tbaxter",
        "https://bsky.app/profile/another.rodeo"
      ],
      "description": "Senior Technology Executive | Digital Services & Agile Transformation | Builder of High-Impact Teams and other good things | Navigator of ambiguity | Endorsed for Banter."
    }
    </script>
  </body>
</html>
